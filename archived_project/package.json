{
  "name": "feedbacks-dev",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter @feedbacks/dashboard dev",
    "build": "pnpm -r --parallel build",
    "widget:dev": "pnpm --filter @feedbacks/widget dev",
    "widget:build": "pnpm --filter @feedbacks/widget build",
    "dashboard:dev": "pnpm --filter @feedbacks/dashboard dev",
    "dashboard:build": "pnpm --filter @feedbacks/dashboard build",
    "type-check": "pnpm -r --parallel type-check",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "pnpm exec playwright install --with-deps"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "shadcn": "^3.2.1",
    "typescript": "^5.0.0",
    "@playwright/test": "^1.45.0"
  },
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
